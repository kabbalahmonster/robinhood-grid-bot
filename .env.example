# Wallet Configuration
PRIVATE_KEY=your_private_key_here

# 0x API Configuration
ZEROX_API_KEY=your_0x_api_key_here

# Trading Configuration
CHECK_INTERVAL_MS=30000
MAX_POSITIONS=10
BUY_COOLDOWN_MS=60000

# Feature Flags (true/false)
BANK_PROFIT=true
SELLS_ACTIVE=true
BUYS_ACTIVE=true
BANK_MOONBAG=true
STOPLOSS_ACTIVE=true

# Moonbag Settings
MOONBAG_PERCENTAGE=20

# Stop Loss Settings
STOPLOSS_PERCENTAGE=-10

# Grid Settings
GRID_SIZE_USD=100
GRID_SPACING_PERCENT=3.72
PROFIT_THRESHOLD_PERCENT=5

# Grid Mode: pregenerated | autogenerate | dynamic
# - pregenerated: Load positions from positions.json
# - autogenerate: Generate all grid positions at startup
# - dynamic: Create positions on-demand as price drops (DCA mode)
GRID_MODE=dynamic

# Buy Amount Mode: static | dynamic
# - static: Use fixed GRID_SIZE_USD for every buy (default)
# - dynamic: Calculate buy amount based on available balance divided by empty positions
#            This enables auto-compounding - profits are redistributed into remaining positions
BUY_AMOUNT_MODE=static

# Gas Reserve (in ETH) - Amount to reserve for gas fees when using dynamic buy mode
# Only used when BUY_AMOUNT_MODE=dynamic
# Default: 0.01 ETH
GAS_RESERVE_ETH=0.01

# Token Addresses (Robinhood Chain - Chain ID 4663)
USDG_ADDRESS=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168
WETH_ADDRESS=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73

# RPC Configuration
RPC_URL=https://robinhood.rh-chain.com
CHAIN_ID=4663
