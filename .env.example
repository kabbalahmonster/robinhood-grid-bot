# ============================================
# ROBINHOOD GRID BOT CONFIGURATION
# ============================================
# This is a comprehensive configuration file for the Robinhood Chain Grid Bot.
# Each setting includes inline documentation explaining its purpose.
# 
# QUICK START:
# 1. Set PRIVATE_KEY and ZEROX_API_KEY
# 2. Adjust GRID_SIZE_USD based on your capital
# 3. Run the bot with: npm run build && npm start
#
# For detailed documentation, see CONFIG.md
# ============================================

# --------------------------------------------
# WALLET & API KEYS (REQUIRED)
# --------------------------------------------

# Your wallet's private key (64 hex characters, with or without 0x prefix)
# WARNING: Never share or commit this! Store it securely.
# Get from MetaMask or your wallet: Account → Export Private Key
PRIVATE_KEY=your_private_key_here

# 0x API Key for swap quotes and execution
# Get a free key at: https://0x.org/
# Required for fetching prices and executing trades
ZEROX_API_KEY=your_0x_api_key_here

# --------------------------------------------
# CHAIN CONFIGURATION
# --------------------------------------------

# RPC URL for Robinhood Chain
# Mainnet: https://rpc.robinhoodchain.com
# Testnet: https://testnet.rpc.robinhoodchain.com
RPC_URL=https://rpc.robinhoodchain.com

# Chain ID for Robinhood Chain
# Mainnet: 4663
# Testnet: 4664
CHAIN_ID=4663

# --------------------------------------------
# TOKEN ADDRESSES (Robinhood Chain)
# --------------------------------------------

# USDG - The stablecoin used for banking profits and grid positions
# Default: 0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168
USDG_ADDRESS=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168

# WETH - Wrapped ETH for ETH-based trading pairs
# Default: 0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
WETH_ADDRESS=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73

# --------------------------------------------
# GRID MODE
# --------------------------------------------
# Determines how grid positions are created and managed
#
# Options:
# - pregenerated: Load positions from positions.json file (manual control)
# - autogenerate: Create all positions at startup from current price (full grid)
# - dynamic: Create positions on-demand as price drops (DCA mode, RECOMMENDED)
#
# Recommendation: Use 'dynamic' for most strategies
GRID_MODE=dynamic

# --------------------------------------------
# BUY AMOUNT MODE
# --------------------------------------------
# Determines how buy amounts are calculated
#
# Options:
# - static: Fixed GRID_SIZE_USD per position (simple, predictable)
# - dynamic: Divide wallet balance by empty positions (auto-compound, RECOMMENDED)
#
# Dynamic mode automatically reinvests profits into remaining positions,
# compounding your returns over time.
#
# Recommendation: Use 'dynamic' for auto-compounding
BUY_AMOUNT_MODE=dynamic

# --------------------------------------------
# GRID SETTINGS
# --------------------------------------------

# Grid size in USD - Amount to spend per grid position
# 
# Conservative: $5-10 per position
# Moderate: $20-50 per position  
# Aggressive: $100+ per position
#
# Note: With dynamic buy mode, this becomes the initial target,
# and amounts adjust based on available capital
GRID_SIZE_USD=10

# Maximum number of grid positions to hold simultaneously
# 
# More positions = finer price granularity but more capital required
# 
# Conservative: 10 positions
# Moderate: 20 positions
# Aggressive: 50+ positions
MAX_POSITIONS=20

# Grid spacing percentage - Distance between price levels
# 
# Example: 5% means next buy level is 5% below the previous one
# 
# Conservative: 10% (wider spacing, fewer trades)
# Moderate: 5% (balanced approach, RECOMMENDED)
# Aggressive: 2-3% (tight spacing, more trades)
GRID_SPACING_PERCENT=5

# --------------------------------------------
# PROFIT SETTINGS
# --------------------------------------------

# Profit threshold percentage - Target profit per grid level
# 
# Example: 5% means sell when position reaches 5% profit
# 
# Conservative: 3-5% (higher win rate, smaller profits)
# Aggressive: 10-15% (lower win rate, larger profits)
PROFIT_THRESHOLD_PERCENT=5

# Minimum profit multiplier - Minimum sell price relative to cost basis
# 
# Example: 1.05 = 5% minimum profit
# This is the hard floor for any sell (prevents selling at loss)
# 
# Should be slightly higher than PROFIT_THRESHOLD_PERCENT to account for fees
MIN_PROFIT=1.05

# Minimum amount to bank (in USD)
# 
# Profits below this threshold won't be moved to bank
# Prevents dust transactions and wasted gas
# 
# Conservative: $2-5
# Default: $1 (suitable for small grids)
BANK_MIN_AMOUNT=1.0

# --------------------------------------------
# MOONBAG SETTINGS
# --------------------------------------------

# Enable moonbag feature - Keep a percentage of tokens when selling
# 
# When enabled, on each sell the bot keeps a portion of tokens
# in case the price continues to rise (FOMO protection)
BANK_MOONBAG=true

# Moonbag percentage - Percentage of tokens to keep on sell
# 
# Example: 10% = Keep 10% of tokens, sell 90%
# 
# Conservative: 20-30% (more upside capture)
# Moderate: 10-15%
# Aggressive: 0-5% (mostly sell all)
MOONBAG_PERCENTAGE=10

# --------------------------------------------
# STOP LOSS SETTINGS
# --------------------------------------------

# Enable stop loss protection
# 
# When enabled, positions hitting the stop loss price will be
# fully liquidated to prevent further losses
STOPLOSS_ACTIVE=true

# Stop loss percentage - Maximum loss before auto-sell
# 
# Must be NEGATIVE (e.g., -10 = sell at 10% loss)
# 
# Conservative: -5% to -10%
# Moderate: -10% to -15%
# Aggressive: -20% or disable (null)
STOPLOSS_PERCENTAGE=-10

# --------------------------------------------
# TIMING SETTINGS
# --------------------------------------------

# Check interval in milliseconds - How often to scan for opportunities
# 
# Robinhood Chain has fast finality, so shorter intervals work well
# 
# Conservative: 30000 (30 seconds)
# Moderate: 10000 (10 seconds, RECOMMENDED)
# Aggressive: 5000 (5 seconds)
CHECK_INTERVAL_MS=10000

# Buy cooldown in milliseconds - Minimum time between buy executions
# 
# Prevents rapid-fire buying during volatility
# 
# Conservative: 60000 (60 seconds)
# Moderate: 30000 (30 seconds, RECOMMENDED)
# Aggressive: 10000 (10 seconds)
BUY_COOLDOWN_MS=30000

# --------------------------------------------
# GAS SETTINGS
# --------------------------------------------

# Gas reserve in ETH - Amount to reserve for gas fees
# 
# Only used when BUY_AMOUNT_MODE=dynamic
# Ensures there's always gas money for transactions
# 
# Robinhood Chain has very low gas costs, so 0.001 ETH is plenty
# 
# Default: 0.001 ETH (sufficient for Robinhood Chain)
GAS_RESERVE_ETH=0.001

# --------------------------------------------
# FEATURE TOGGLES
# --------------------------------------------

# Enable profit banking - Move profits to USDG stablecoin
# When disabled, profits stay in the traded token
BANK_PROFIT=true

# Enable sells - Allow the bot to execute sell orders
# Disable to accumulate only (buy-only mode)
SELLS_ACTIVE=true

# Enable buys - Allow the bot to execute buy orders
# Disable to wind down positions (sell-only mode)
BUYS_ACTIVE=true
